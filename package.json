    "@libsql/client": "^0.14",
    "bcryptjs": "^3",
    "date-fns": "^4",
    "jose": "^5",
    "lucide-react": "^1",
    "nodemailer": "^9",
    "react-hook-form": "^7",
    "recharts": "^3",
    "zod": "^4",
    "@hookform/resolvers": "^5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3",
    "@types/node": "^20",
    "@types/nodemailer": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
